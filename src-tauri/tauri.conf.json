{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BTS Light",
  "version": "0.9.167",
  "identifier": "de.badhub.btslight",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BTS Light",
        "width": 900,
        "height": 640,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./installer/firewall-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://badhub.de/download/bts-light/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2NjI4MzY5OUY1NUEzRTIKUldUaW8xV2ZhWU5pNW9sSkRpWVBacjgrYnpqUXdicXpnMjVxbnUyVmMvMHAvTEN6TUx4ZzF1c3cK"
    }
  }
}
